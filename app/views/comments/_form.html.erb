<%= form_with(model: [post, comment]) do |form| %>
  <% if comment.errors.any? %>
    <div class="mb-4 rounded-lg bg-red-100 text-red-800 p-3 text-sm">
      <h2 class="font-semibold mb-2">
        <%= pluralize(comment.errors.count, "error") %> prohibited this comment from being saved:
      </h2>
      <ul class="list-disc list-inside">
        <% comment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if authenticated? %>
    <%= form.hidden_field :user_id, value: Current.user.id %>
  <% else %>
    <div class="mb-4">
      <%= form.label :guest_name, "Name", class: "block font-medium text-gray-700 mb-1" %>
      <%= form.text_field :guest_name, class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :content, "Comment", class: "block font-medium text-gray-700 mb-1" %>
    <%= form.text_area :content, rows: 4, class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= form.hidden_field :post_id, value: post.id %>
    <%= form.submit "Publish Comment", class: "bg-blue-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-blue-700 transition" %>
  </div>
<% end %>
