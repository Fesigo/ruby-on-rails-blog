<% content_for :title, "Editing post" %>

<div class="max-w-3xl mx-auto mt-8 px-4">
  <h1 class="text-3xl font-bold mb-6 text-gray-900">Editing Post</h1>

  <div class="mb-6">
    <%= render "form", post: @post %>
  </div>

  <div class="flex gap-4">
    <%= link_to "Cancel", @post, class: "text-red-600 hover:underline font-medium" %> |
    <%= link_to "Back to posts", posts_path, class: "text-gray-600 hover:underline" %>
  </div>
</div>
