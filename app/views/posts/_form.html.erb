<%= form_with(model: post) do |form| %>
  <% if post.errors.any? %>
    <div class="mb-4 rounded-lg bg-red-100 text-red-800 p-3 text-sm">
      <h2 class="font-semibold mb-2">
        <%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:
      </h2>
      <ul class="list-disc list-inside">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :title, class: "block font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title, class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :content, class: "block font-medium text-gray-700 mb-1" %>
    <%= form.text_area :content, rows: 6, class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <%= form.hidden_field :user_id, value: Current.user.id %>

  <div>
    <%= form.submit class: "bg-blue-600 text-white font-medium px-4 py-2 rounded-lg hover:bg-blue-700 transition" %>
  </div>
<% end %>
